PORT=4000
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=1d
NODE_ENV=development

# Storage mode: "file", "mongo", or "postgres"
STORE_DRIVER=file
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres

# Used only when STORE_DRIVER=mongo
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=working_with_forever_db
MONGO_STATE_COLLECTION=app_state
